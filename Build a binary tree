#include <iostream>
#include <vector>
#include <queue>
using namespace std;
class Node {
public:
    int data;
    Node* left;
    Node* right;
    Node(int val) {
        data = val;
        left = right = NULL;
    }
};
static int idx = -1;
Node* buildTree(vector<int>& preorder) {
    idx++;
    if (preorder[idx] == -1) {
        return NULL;
    }

    Node* root = new Node(preorder[idx]);
    root->left = buildTree(preorder);
    root->right = buildTree(preorder);
    return root;
}

// PreOrder Traversal( root,left,right)--time complexity(O(n))

void preOrder(Node* root) {
    if (root == NULL)
        return;
    cout << root->data << "";
    preOrder(root->left);
    preOrder(root->right);
    cout << endl;
}

// InOrder traversal(left,root,right)

void inorder(Node* root) {
    if (root == NULL)
        return;
    inorder(root->left);
    cout << root->data << "";
    inorder(root->right);
    cout << endl;
}
// postorder (left,right,root)
void postorder(Node* root) {
    if (root == NULL)
        return;
    inorder(root->left);

    inorder(root->right);
    cout << root->data << "";
    cout << endl;
}

void levelorder(Node* root) {
    queue<Node*> q;
    q.push(root);
    while (q.size() > 0) {

        Node* curr = q.front();
        q.pop();
        cout << curr->data << "";
        if (curr->left != NULL) {
            q.push(curr->left);
        }
        if (curr->right != NULL) {
            q.push(curr->right);
        }
    }
}

int main() {
    vector<int> preorder = {1, 2, -1, -1, 3, 4, -1, -1, 5, -1, -1};
    Node* root = buildTree(preorder);
    preOrder(root);
    inorder(root);

    levelorder(root);
     cout << endl;
    cout << root->data << endl;
    cout << root->left->data << endl;
    cout << root->right->data << endl;

    return 0;
}
