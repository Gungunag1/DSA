class Solution {
public:
    int minimumCost(vector<int>& cost) {
        sort(cost.begin(), cost.end(), greater<int>());
        int sum = 0;
       
        for (int i = 0; i < cost.size(); i++) {
            if (i % 3 != 2) { // every 3rd candy is free
                sum += cost[i];
            }
             if (cost.size() == 1)return cost[i];

        }
        return sum;
    }
};
