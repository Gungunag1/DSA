class Solution {
public:
    int minOperations(string s) {
     int n = s.length();
        int pattern1 = 0;
        int pattern2 = 0;

        for(int i = 0; i < n; i++) {
            
            // pattern "0101..."
            if(s[i] != (i % 2 ? '1' : '0'))
                pattern1++;

            // pattern "1010..."
            if(s[i] != (i % 2 ? '0' : '1'))
                pattern2++;
        }

        return min(pattern1, pattern2);    
    }
};
